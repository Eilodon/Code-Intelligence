{
  "mcpServers": {
    "hex-graph": {
      "command": "hex-graph-mcp",
      "args": [],
      "env": {}
    },
    "hex-line": {
      "command": "hex-line-mcp",
      "args": [],
      "env": {}
    },
    "semble": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "semble[mcp]", "semble"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@colbymchenry/codegraph", "serve", "--mcp"],
      "env": {
        "CODEGRAPH_MCP_TOOLS": "explore,node,search,callers,callees,impact,files,status"
      }
    },
    "ci": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-launcher.sh"],
      "env": {}
    }
  }
}
