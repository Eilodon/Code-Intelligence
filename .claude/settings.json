{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-agents-md.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-build-ci.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Bash|mcp__ci__edit_context|mcp__ci__diff_impact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ci-nudge.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
